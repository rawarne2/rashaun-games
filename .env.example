# Backend Socket.IO server for the preferences game.
# Production:  wss://preferences-game-backend.onrender.com
# Local dev:   http://localhost:3001 (you must run preferences-game-backend on port 3001
#              because the Next dev server already uses port 3000)
NEXT_PUBLIC_WEBSOCKET_SERVER_URL=

# "true" if pointing at the production Render backend, "false" if local
NEXT_PUBLIC_IS_PRODUCTION=
